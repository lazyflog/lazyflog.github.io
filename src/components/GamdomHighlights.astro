---
const tabs = ['Casino', 'Sports', 'Live'];
const slideItems = ['⚽ Soccer', '🏀 Basketball', '🎾 Tennis', '🏈 Football', '⚾ Baseball', '🏒 Hockey'];
---

<div class="mt-5">
  <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-3">
    Component Highlights
  </p>

  <div class="grid sm:grid-cols-3 gap-3">

    <!-- TabSelector -->
    <div class="bg-gray-950 border border-gray-800 rounded-xl overflow-hidden">
      <div class="px-3.5 py-2.5 border-b border-gray-800">
        <code class="text-teal-400 text-xs font-mono">&lt;TabSelector /&gt;</code>
      </div>
      <div class="p-3">
        <div class="relative flex bg-gray-900 rounded-lg p-1" id="tab-wrap">
          <div
            id="tab-indicator"
            class="absolute bg-gray-700 rounded-md pointer-events-none"
            style="height: calc(100% - 8px); top: 4px; left: 4px; transition: left 0.25s ease, width 0.25s ease;"
          ></div>
          {tabs.map((tab, i) => (
            <button
              class:list={[
                'tab-btn relative z-10 px-3 py-1.5 text-xs font-medium rounded-md whitespace-nowrap',
                i === 0 ? 'text-teal-400' : 'text-gray-500',
              ]}
            >
              {tab}
            </button>
          ))}
        </div>
        <p class="mt-3 text-gray-500 text-xs leading-relaxed">
          선택 탭에 배경이 따라오는 슬라이딩 인디케이터. 라이브러리 없이 <code class="text-gray-400 font-mono">offsetLeft</code>로 직접 위치 계산.
        </p>
      </div>
    </div>

    <!-- BottomSheetModal -->
    <div class="bg-gray-950 border border-gray-800 rounded-xl overflow-hidden">
      <div class="px-3.5 py-2.5 border-b border-gray-800">
        <code class="text-teal-400 text-xs font-mono">&lt;BottomSheetModal /&gt;</code>
      </div>
      <div class="p-3">
        <div class="relative overflow-hidden bg-gray-900 rounded-lg" style="height: 76px;">
          <div class="flex items-center justify-center h-full">
            <button
              id="sheet-open"
              class="text-xs bg-teal-500/15 text-teal-400 border border-teal-500/30 px-3 py-1.5 rounded-lg font-medium"
            >
              Open Sheet
            </button>
          </div>
          <div
            id="sheet-overlay"
            class="absolute inset-0 pointer-events-none"
            style="background: rgba(0,0,0,0); transition: background 0.3s ease;"
          ></div>
          <div
            id="sheet-panel"
            class="absolute bottom-0 left-0 right-0 bg-gray-700 rounded-t-xl px-3 py-2.5"
            style="transform: translateY(100%); transition: transform 0.3s ease;"
          >
            <div class="flex items-center justify-between">
              <span class="text-white text-xs font-medium">Select Currency</span>
              <button id="sheet-close" class="text-gray-400 text-xs px-1">✕</button>
            </div>
          </div>
        </div>
        <p class="mt-3 text-gray-500 text-xs leading-relaxed">
          Context + Portal 기반 Compound Component. Trigger · Overlay · Content를 직접 구현. 애니메이션 후 unmount 처리.
        </p>
      </div>
    </div>

    <!-- SlideSelector -->
    <div class="bg-gray-950 border border-gray-800 rounded-xl overflow-hidden">
      <div class="px-3.5 py-2.5 border-b border-gray-800">
        <code class="text-teal-400 text-xs font-mono">&lt;SlideSelector /&gt;</code>
      </div>
      <div class="p-3">
        <div class="relative" id="slide-wrap">
          <div
            id="slide-scroll"
            class="flex gap-1.5 overflow-x-auto"
            style="scrollbar-width: none; -ms-overflow-style: none;"
          >
            {slideItems.map((item) => (
              <button class="flex-shrink-0 px-2.5 py-1 text-xs text-gray-400 bg-gray-800 rounded-md whitespace-nowrap">
                {item}
              </button>
            ))}
          </div>
          <div
            id="slide-fade-left"
            class="absolute left-0 top-0 bottom-0 w-8 pointer-events-none"
            style="background: linear-gradient(to right, #030712, transparent); opacity: 0; transition: opacity 0.2s;"
          ></div>
          <div
            id="slide-fade-right"
            class="absolute right-0 top-0 bottom-0 w-8 pointer-events-none"
            style="background: linear-gradient(to left, #030712, transparent); opacity: 1; transition: opacity 0.2s;"
          ></div>
        </div>
        <p class="mt-3 text-gray-500 text-xs leading-relaxed">
          스크롤 위치에 따라 양끝 그라디언트 페이드 자동 제어. 모바일 스크롤 다운 시 컨테이너 hide.
        </p>
      </div>
    </div>

  </div>
</div>

<script>
  // ── TabSelector ──────────────────────────────────────
  const tabWrap = document.getElementById('tab-wrap');
  const tabIndicator = document.getElementById('tab-indicator') as HTMLElement | null;
  const tabBtns = tabWrap?.querySelectorAll<HTMLButtonElement>('.tab-btn');

  function moveIndicator(btn: HTMLButtonElement) {
    if (!tabIndicator) return;
    tabIndicator.style.width = `${btn.offsetWidth}px`;
    tabIndicator.style.left = `${btn.offsetLeft}px`;
  }

  if (tabBtns && tabBtns.length > 0) {
    requestAnimationFrame(() => moveIndicator(tabBtns[0]));

    tabBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        tabBtns.forEach((b) => {
          b.classList.remove('text-teal-400');
          b.classList.add('text-gray-500');
        });
        btn.classList.remove('text-gray-500');
        btn.classList.add('text-teal-400');
        moveIndicator(btn);
      });
    });
  }

  // ── BottomSheetModal ─────────────────────────────────
  const sheetOpen = document.getElementById('sheet-open');
  const sheetClose = document.getElementById('sheet-close');
  const sheetOverlay = document.getElementById('sheet-overlay') as HTMLElement | null;
  const sheetPanel = document.getElementById('sheet-panel') as HTMLElement | null;

  function openSheet() {
    if (!sheetPanel || !sheetOverlay) return;
    sheetPanel.style.transform = 'translateY(0)';
    sheetOverlay.style.background = 'rgba(0,0,0,0.55)';
    sheetOverlay.style.pointerEvents = 'auto';
  }

  function closeSheet() {
    if (!sheetPanel || !sheetOverlay) return;
    sheetPanel.style.transform = 'translateY(100%)';
    sheetOverlay.style.background = 'rgba(0,0,0,0)';
    sheetOverlay.style.pointerEvents = 'none';
  }

  sheetOpen?.addEventListener('click', openSheet);
  sheetClose?.addEventListener('click', closeSheet);
  sheetOverlay?.addEventListener('click', closeSheet);

  // ── SlideSelector ────────────────────────────────────
  const slideScroll = document.getElementById('slide-scroll') as HTMLElement | null;
  const fadLeft = document.getElementById('slide-fade-left') as HTMLElement | null;
  const fadRight = document.getElementById('slide-fade-right') as HTMLElement | null;

  function updateFade() {
    if (!slideScroll || !fadLeft || !fadRight) return;
    const { scrollLeft, scrollWidth, clientWidth } = slideScroll;
    fadLeft.style.opacity = scrollLeft > 2 ? '1' : '0';
    fadRight.style.opacity = scrollLeft + clientWidth < scrollWidth - 2 ? '1' : '0';
  }

  slideScroll?.addEventListener('scroll', updateFade, { passive: true });
  updateFade();
</script>