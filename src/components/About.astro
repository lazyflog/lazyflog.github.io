---
import { aboutData } from '../data/portfolio';

const { bio, skills } = aboutData;
---

<section id="about" class="py-24 border-t border-gray-100 dark:border-gray-800">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-12">
      About
      <span class="block mt-1 w-12 h-1 bg-teal-500 rounded"></span>
    </h2>

    <div class="grid sm:grid-cols-2 gap-12 items-start">
      <div class="space-y-4">
        {bio.map((paragraph) => (
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed text-base">
            {paragraph}
          </p>
        ))}
      </div>

      <div>
        <p class="text-sm font-semibold text-gray-500 dark:text-gray-500 uppercase tracking-wider mb-4">
          Tech Stack
        </p>
        <div class="flex flex-wrap gap-2">
          {skills.map((skill) => (
            <span class="px-3 py-1.5 text-sm font-medium bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-md">
              {skill}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
