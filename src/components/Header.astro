  <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="#hero" class="text-lg font-bold text-gray-900 dark:text-white hover:text-teal-500 dark:hover:text-teal-400 transition-colors">
      JS's Page
    </a>

    <nav class="hidden sm:flex items-center gap-6 text-sm font-medium text-gray-600 dark:text-gray-400">
      <a href="#about" class="hover:text-teal-500 dark:hover:text-teal-400 transition-colors">About</a>
      <a href="#projects" class="hover:text-teal-500 dark:hover:text-teal-400 transition-colors">Projects</a>
      <a href="#side-projects" class="hover:text-teal-500 dark:hover:text-teal-400 transition-colors">Side</a>
