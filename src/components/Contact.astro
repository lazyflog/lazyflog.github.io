---
import { contactData } from '../data/portfolio';

const { cta, ctaEn, email } = contactData;
---

<section id="contact" class="py-24 border-t border-gray-100 dark:border-gray-800">
  <div class="max-w-5xl mx-auto px-6 text-center">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
      Contact
    </h2>
    <p class="lang-ko text-gray-600 dark:text-gray-400 mb-8 max-w-md mx-auto">
      {cta}
    </p>
    <p class="lang-en text-gray-600 dark:text-gray-400 mb-8 max-w-md mx-auto">
      {ctaEn}
    </p>
    <a
      href={`mailto:${email}`}
      class="inline-flex items-center gap-2 px-8 py-3.5 bg-teal-500 hover:bg-teal-600 text-white font-medium rounded-lg transition-colors text-base"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
      {email}
    </a>
  </div>
</section>
