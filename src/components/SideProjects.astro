---
import { sideProjectsData } from '../data/portfolio';
import GamdomHighlights from './GamdomHighlights.astro';
---

<section id="side-projects" class="py-24 border-t border-gray-100 dark:border-gray-800">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
      Side Projects
      <span class="block mt-1 w-12 h-1 bg-teal-500 rounded"></span>
    </h2>
    <p class="text-gray-500 dark:text-gray-500 text-sm mb-12">개인적으로 만든 것들입니다.</p>

    <div class="space-y-6">
      {sideProjectsData.map((project) => (
        <article class="bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl overflow-hidden">
          <div class="p-6">
            <div class="flex flex-wrap items-center gap-3 mb-3">
              <h3 class="text-lg font-bold text-gray-900 dark:text-white">{project.title}</h3>
              {project.links?.repo && (
                <a
                  href={project.links.repo}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 text-xs font-medium text-gray-500 dark:text-gray-500 hover:text-teal-500 dark:hover:text-teal-400 transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                  </svg>
                  GitHub
                </a>
              )}
            </div>
            <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-6">{project.description}</p>

            <div class="grid sm:grid-cols-2 gap-4">
              {project.coverage.map((group) => (
                <div class="bg-white dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700/50 rounded-lg p-4">
                  <p class="text-xs font-semibold text-teal-500 dark:text-teal-400 uppercase tracking-wider mb-3">
                    {group.label}
                  </p>
                  <ul class="space-y-1.5">
                    {group.topics.map((topic) => (
                      <li class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
                        <span class="w-1 h-1 rounded-full bg-teal-500/60 dark:bg-teal-400/60 shrink-0"></span>
                        {topic}
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>

            {project.id === 'gamdom-clone' && <GamdomHighlights />}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
