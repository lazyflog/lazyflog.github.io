---
const persona = {
  name: '우준희',
  nameEn: 'Woo Junhee',
  age: 31,
  region: '경기 수원시',
  regionEn: 'Suwon, Gyeonggi',
  job: 'IT 개발자',
  jobEn: 'IT Developer',
  pet: '골든리트리버 4살 (맥스)',
  petEn: 'Golden Retriever, 4 y.o. (Max)',
  style: '유머러스하고 솔직한 말투, 정보 전달 중심, 아재 개그 가끔',
  styleEn: 'Humorous and candid, info-focused, occasional dad jokes',
  professional_persona: '우준희 씨는 경기 수원시 소재 IT 기업에서 근무하는 31세 개발자로, 백엔드 및 IoT 연동 시스템 개발에 강점을 가지고 있다. 코드 품질과 효율성을 중시하며, 반려동물 관련 스마트 기기에 관심이 많아 업무 외 시간에도 펫테크 분야 기술 트렌드를 꾸준히 탐색한다. 팀 내에서는 유머러스한 분위기 메이커로 통하지만, 기술적인 문제 앞에서는 날카롭고 논리적인 면모를 드러낸다.',
  professional_personaEn: 'Woo Junhee is a 31-year-old developer at an IT company in Suwon, Gyeonggi, with strengths in backend and IoT integration systems. He values code quality and efficiency, and actively follows pet-tech trends in his spare time. Known as a humorous mood-maker on his team, he shows sharp logical thinking when tackling technical problems.',
};

const post = {
  board: '자유게시판',
  boardEn: 'Free Board',
  title: '맥스한테 스마트 급수기 달아줬더니 본인이 더 신기한가봄 ㅋㅋ',
  titleEn: "Got Max a smart water dispenser and he's more confused than hydrated lol",
  lines: [
    '어제 해외직구로 주문했던 IoT 급수기 드디어 도착했습니다 ㅎㅎ',
    '설치하면서 앱 연동하느라 한 시간 날렸는데 결국 맥스는 그냥 물 마시고 가더라고요...',
    '근데 제가 카메라로 들여다보니까 맥스가 앱 알림 소리 들릴 때마다 급수기 앞에서 고개 갸웃거리는 거 포착 ㅋㅋ',
    '솔직히 급수기보다 맥스 반응 모니터링하려고 산 것 같기도 해요 😂',
    '혹시 스마트 급수기 써보신 분들 있나요? 필터 교체 주기가 좀 짧은 것 같아서 다른 제품도 궁금하네요~',
  ],
  linesEn: [
    'My IoT water dispenser from overseas finally arrived yesterday!!',
    'Spent an hour connecting the app during setup, and Max just walked up, drank some water, and left...',
    'But when I checked the camera, I caught Max tilting his head in front of the dispenser every time the app notification sound went off lol',
    "Honestly I think I bought it more to monitor Max's reactions than for the water dispenser itself 😂",
    "Has anyone used a smart water dispenser before? The filter replacement cycle seems kinda short — curious about other products~",
  ],
};
---

<div class="mt-5">
  <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-3">
    Example
  </p>

  <div class="grid sm:grid-cols-2 gap-3">

    <!-- Persona Card -->
    <div class="bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700/60 rounded-xl p-4">
      <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-3">Persona</p>
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 rounded-full bg-teal-500/15 dark:bg-teal-400/10 flex items-center justify-center text-base shrink-0">
          🧑‍💻
        </div>
        <div>
          <p class="text-sm font-bold text-gray-900 dark:text-white">
            <span class="lang-ko">{persona.name}</span>
            <span class="lang-en">{persona.nameEn}</span>
          </p>
          <p class="lang-ko text-xs text-gray-500 dark:text-gray-400">{persona.age}세 · {persona.region}</p>
          <p class="lang-en text-xs text-gray-500 dark:text-gray-400">{persona.age} y.o. · {persona.regionEn}</p>
        </div>
      </div>
      <dl class="space-y-2">
        <div class="flex gap-2">
          <dt class="text-xs text-gray-400 dark:text-gray-500 w-11 shrink-0">
            <span class="lang-ko">직업</span>
            <span class="lang-en">Job</span>
          </dt>
          <dd class="text-xs text-gray-700 dark:text-gray-300">
            <span class="lang-ko">{persona.job}</span>
            <span class="lang-en">{persona.jobEn}</span>
          </dd>
        </div>
        <div class="flex gap-2">
          <dt class="text-xs text-gray-400 dark:text-gray-500 w-11 shrink-0">
            <span class="lang-ko">반려동물</span>
            <span class="lang-en">Pet</span>
          </dt>
          <dd class="text-xs text-gray-700 dark:text-gray-300">
            <span class="lang-ko">{persona.pet}</span>
            <span class="lang-en">{persona.petEn}</span>
          </dd>
        </div>
        <div class="flex gap-2">
          <dt class="text-xs text-gray-400 dark:text-gray-500 w-11 shrink-0 mt-0.5">
            <span class="lang-ko">말투</span>
            <span class="lang-en">Tone</span>
          </dt>
          <dd class="text-xs text-gray-500 dark:text-gray-400 italic leading-relaxed">
            <span class="lang-ko">{persona.style}</span>
            <span class="lang-en">{persona.styleEn}</span>
          </dd>
        </div>
        <div class="flex gap-2">
          <dt class="text-xs text-gray-400 dark:text-gray-500 w-11 shrink-0 mt-0.5">
            <span class="lang-ko">구체적인 인적사항</span>
            <span class="lang-en">Profile</span>
          </dt>
          <dd class="text-xs text-gray-500 dark:text-gray-400 italic leading-relaxed">
            <span class="lang-ko">{persona.professional_persona}</span>
            <span class="lang-en">{persona.professional_personaEn}</span>
          </dd>
        </div>
      </dl>
    </div>

    <!-- Generated Post -->
    <div class="bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700/60 rounded-xl p-4">
      <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-3">Generated Post</p>
      <div class="space-y-2.5">
        <span class="inline-block text-xs font-medium text-teal-600 dark:text-teal-400 bg-teal-50 dark:bg-teal-400/10 px-2 py-0.5 rounded">
          <span class="lang-ko">{post.board}</span>
          <span class="lang-en">{post.boardEn}</span>
        </span>
        <p class="lang-ko text-sm font-semibold text-gray-900 dark:text-white leading-snug">{post.title}</p>
        <p class="lang-en text-sm font-semibold text-gray-900 dark:text-white leading-snug">{post.titleEn}</p>
        <div class="lang-ko space-y-1.5 pt-0.5">
          {post.lines.map((line) => (
            <p class="text-xs text-gray-600 dark:text-gray-400 leading-relaxed">{line}</p>
          ))}
        </div>
        <div class="lang-en space-y-1.5 pt-0.5">
          {post.linesEn.map((line) => (
            <p class="text-xs text-gray-600 dark:text-gray-400 leading-relaxed">{line}</p>
          ))}
        </div>
      </div>
    </div>

  </div>
</div>
