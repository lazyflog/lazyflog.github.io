---
import { Code } from 'astro:components';
import { sideProjectsData } from '../data/portfolio';

const circuitBreakerCode = `export class CircuitBreaker {
  private failures = 0;
  private lastFailureTime = 0;
  private state: 'CLOSED' | 'OPEN' | 'HALF_OPEN' = 'CLOSED';

  constructor(
    private readonly threshold = 5,
    private readonly resetTime = 60_000,
  ) {}

  async execute<T>(fn: () => Promise<T>): Promise<T> {
    if (this.state === 'OPEN') {
      const elapsed = Date.now() - this.lastFailureTime;
      if (elapsed >= this.resetTime) {
        this.state = 'HALF_OPEN';
      } else {
        const retryIn = Math.ceil((this.resetTime - elapsed) / 1000);
        throw new Error(\`Circuit OPEN — retry in \${retryIn}s\`);
      }
    }

    try {
      const result = await fn();
      this.onSuccess();
      return result;
    } catch (error) {
      this.onFailure();
      throw error;
    }
  }

  private onSuccess() {
    this.failures = 0;
    if (this.state === 'HALF_OPEN') {
      this.state = 'CLOSED';
      logger.info('Circuit CLOSED — service recovered');
    }
  }

  private onFailure() {
    this.failures++;
    this.lastFailureTime = Date.now();
    if (this.failures >= this.threshold) {
      this.state = 'OPEN';
      logger.error(\`Circuit OPENED after \${this.failures} failures\`);
    }
  }
}`;

const parallelAnalysisCode = `async function analyzeWithMCPServersParallel(
  requiredServers: Set<string>,
  files: FileInfo[],
): Promise<Map<string, unknown>> {
  const filesHash = cacheService.generatePRHash(files);

  // 여러 MCP 서버를 병렬로 실행, 일부 실패해도 나머지 결과 활용
  const promises = Array.from(requiredServers).map(async (serverName) => {
    const cached = cacheService.getCachedMCPResult(serverName, filesHash);
    if (cached) return [serverName, cached] as const;

    try {
      const result = await retryHandler.withRetry(
        () => analyzeWithMCPServer(serverName, files),
        { maxRetries: 2, backoff: 1000 },
      );
      cacheService.cacheMCPResult(serverName, filesHash, result);
      return [serverName, result] as const;
    } catch (error) {
      return [serverName, { error: (error as Error).message }] as const;
    }
  });

  const mcpResults = new Map(
    (await Promise.allSettled(promises))
      .filter((r): r is PromiseFulfilledResult<readonly [string, unknown]> =>
        r.status === 'fulfilled',
      )
      .map((r) => r.value),
  );

  // 감지된 스택별로 Claude API 리뷰를 병렬 생성
  const reviewPromises = detectedStacks.map((stack) =>
    anthropicCircuitBreaker.execute(() =>
      retryHandler.withRetry(() =>
        anthropic.messages.create({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 4096,
          messages: [{ role: 'user', content: buildPrompt(stack, mcpResults) }],
        }),
      ),
    ),
  );

  const reviews = await Promise.allSettled(reviewPromises);
  return buildReviewMap(reviews, detectedStacks);
}`;

const snippets = [
  {
    id: 'circuit-breaker',
    label: 'Circuit Breaker',
    description: 'API 장애 자동 차단 및 복구 패턴',
    code: circuitBreakerCode,
  },
  {
    id: 'parallel-analysis',
    label: 'Parallel AI Analysis',
    description: 'MCP 서버 병렬 분석 + Claude API 리뷰 생성',
    code: parallelAnalysisCode,
  },
];
---

<section id="side-projects" class="py-24 border-t border-gray-100 dark:border-gray-800">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
      Side Projects
      <span class="block mt-1 w-12 h-1 bg-teal-500 rounded"></span>
    </h2>
    <p class="text-gray-500 dark:text-gray-500 text-sm mb-12">개인적으로 만든 도구들입니다.</p>

    <div class="space-y-8">
      {sideProjectsData.map((project) => (
        <article class="bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl overflow-hidden">
          <div class="p-6">
            <div class="flex flex-wrap items-center gap-3 mb-2">
              <h3 class="text-base font-bold text-gray-900 dark:text-white">{project.title}</h3>
            </div>
            <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-4">{project.description}</p>
            <div class="flex flex-wrap gap-1.5">
              {project.tags.map((tag) => (
                <span class="px-2 py-0.5 text-xs bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 rounded font-mono">
                  {tag}
                </span>
              ))}
            </div>
          </div>

          <!-- Code Showcase -->
          <div class="border-t border-gray-200 dark:border-gray-800">
            <!-- Tabs -->
            <div class="flex gap-0 border-b border-gray-200 dark:border-gray-800 px-4 pt-3">
              {snippets.map((snippet, i) => (
                <button
                  class="code-tab px-4 py-2 text-xs font-medium rounded-t-md transition-colors"
                  data-tab={snippet.id}
                  data-active={i === 0 ? 'true' : 'false'}
                >
                  {snippet.label}
                </button>
              ))}
            </div>

            <!-- Code Panels -->
            {snippets.map((snippet, i) => (
              <div
                id={`panel-${snippet.id}`}
                class="code-panel"
                style={i !== 0 ? 'display:none' : ''}
              >
                <div class="flex items-center justify-between px-4 py-2 bg-gray-100 dark:bg-gray-800/60">
                  <span class="text-xs text-gray-500 dark:text-gray-500 font-mono">{snippet.description}</span>
                  <span class="text-xs text-gray-400 dark:text-gray-600 font-mono">TypeScript</span>
                </div>
                <div class="overflow-x-auto text-sm [&>pre]:!m-0 [&>pre]:!rounded-none [&>pre]:p-5 [&>pre]:!bg-gray-950">
                  <Code code={snippet.code} lang="typescript" theme="github-dark" />
                </div>
              </div>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .code-tab[data-active='true'] {
    background-color: oklch(13% 0.028 261.692);
    color: rgb(45, 212, 191);
    border-bottom: 2px solid rgb(45, 212, 191);
  }
  .code-tab[data-active='false'] {
    color: oklch(55.1% 0.027 264.364);
  }
  .code-tab[data-active='false']:hover {
    color: oklch(70.7% 0.022 261.325);
    background-color: oklch(21% 0.034 264.665 / 0.5);
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.code-tab');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const targetId = tab.dataset.tab!;

      tabs.forEach((t) => t.setAttribute('data-active', 'false'));
      tab.setAttribute('data-active', 'true');

      document.querySelectorAll<HTMLElement>('.code-panel').forEach((panel) => {
        panel.style.display = panel.id === `panel-${targetId}` ? '' : 'none';
      });
    });
  });
</script>
